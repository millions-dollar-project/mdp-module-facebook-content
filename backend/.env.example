# Copy to .env (gitignored) and fill in. The defaults below match
# docker-compose.yml so `make db-up && make run` works out of the box
# for local dev.

# --- HTTP server ---
PORT=8081

# --- Postgres (matches docker-compose.yml) ---
DATABASE_URL=postgres://facebook:facebook@localhost:5433/facebook?sslmode=disable

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info

# --- Background worker (publishes scheduled_posts rows that are due) ---
WORKER_INTERVAL=60s

# --- Graceful shutdown ---
SHUTDOWN_TIMEOUT=10s

# --- Outbound HTTP timeout (Graph API calls) ---
REQUEST_TIMEOUT=15s

# --- Facebook Graph API ---
# App ID + Secret from https://developers.facebook.com/apps
# FACEBOOK_APP_SECRET is write-only server-side; never returned via GET /config.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=facebook-verify-token
FACEBOOK_GRAPH_API_VERSION=v18.0
FACEBOOK_GRAPH_API_BASE=https://graph.facebook.com

# --- CORS ---
# Comma-separated origins. Vite dev server defaults to 5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# =============================================================================
# AI providers (Kling + OpenAI only)
# Not used by Phase 2 (AI is an echo stub), wired here for Phase 3+ so the
# config layer doesn't need a second pass.
# =============================================================================

# --- OpenAI (text generation: content rewrite, comment replies) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Kling (video / image generation: AutoPost campaigns) ---
KLING_API_KEY=
KLING_API_BASE=https://api.klingai.com

# AI provider routing for Phase 3+ services:
#   "openai" — text work (comment replies, rewrites)
#   "kling"  — visual work (videos, AI images for posts)
#   "echo"   — current stub, returns "[AI-STUB] <original>"
AI_PROVIDER_TEXT=echo
AI_PROVIDER_VISUAL=echo

# =============================================================================
# Google Sheets auto-export (Phase 3+ AutoPost campaigns)
# Service account from https://console.cloud.google.com/iam-admin/serviceaccounts
# =============================================================================

# Spreadsheet ID from URL https://docs.google.com/spreadsheets/d/{THIS}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Raw JSON content of the service account key (entire file as one line).
# Preferred when running inside Docker — no file mount needed.
# Leave empty and set GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH instead if you prefer a file.
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

# Alternative: path to the JSON key file (used when the inline form is empty).
GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH=./config/google-service-account.json

# Comma-separated hours to auto-export (24h format). Default: 08:00,12:00,18:00,20:00
GOOGLE_SHEETS_EXPORT_HOURS=08:00,12:00,18:00,20:00
